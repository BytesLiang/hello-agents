# Knowledge QA application
KNOWLEDGE_QA_RETRIEVAL_TOP_K=5
KNOWLEDGE_QA_ANSWER_CONTEXT_TOP_K=4
KNOWLEDGE_QA_MAX_CITATIONS=4
KNOWLEDGE_QA_MIN_RETRIEVED_CHUNKS=1
KNOWLEDGE_QA_ANSWER_MAX_TOKENS=512
KNOWLEDGE_QA_STORE_PATH=.hello_agents/knowledge_bases.json
KNOWLEDGE_QA_TRACE_PATH=.hello_agents/knowledge_qa_traces.jsonl
KNOWLEDGE_QA_UPLOAD_ROOT=.hello_agents/uploads
KNOWLEDGE_QA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://tauri.localhost,https://tauri.localhost,tauri://localhost

# Shared LLM configuration
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key

# Shared RAG configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v4
EMBED_API_KEY=your-embedding-api-key
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
