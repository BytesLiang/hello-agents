LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-api-key
TAVILY_API_KEY=your-tavily-api-key

# Local OpenAI-compatible example
# LLM_MODEL=qwen2.5:14b
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_PROVIDER=ollama
# LLM_API_KEY=EMPTY

# Memory store defaults
# MEMORY_SQLITE_PATH=.hello_agents/memory.sqlite3
# MEMORY_WORKING_TTL_SECONDS=86400
# MEMORY_WORKING_MAX_ENTRIES=24

# Optional Qdrant vector index
# QDRANT_URL=https://your-qdrant-host:6333
# QDRANT_API_KEY=your-qdrant-api-key
# QDRANT_COLLECTION_NAME=hello_agents_memory

# Optional DashScope / BaiLian embedding backend
# EMBED_MODEL_TYPE=dashscope
# EMBED_MODEL_NAME=text-embedding-v3
# EMBED_API_KEY=your-embed-api-key
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional Neo4j placeholder config
# NEO4J_URL=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password
